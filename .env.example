# =============================================================================
#  .env.example
#  -----------------------------------------------------------------------------
#  Template for the environment variables required to run this project.
#
#  USAGE:
#      1. Copy this file to `.env`:    cp .env.example .env
#      2. Fill in the blank values with credentials appropriate for your
#         environment. NEVER commit the populated `.env` file.
#
#  NOTE: All values are intentionally left blank. The `.env` file itself is
#        listed in `.gitignore` to prevent credential leaks.
# =============================================================================

# ---- Postgres container (consumed by docker-compose.yml) --------------------
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ---- Application-side connection settings -----------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=

# ---- Full connection URL (optional; useful for ORMs and `psql`) -------------
#  Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=
