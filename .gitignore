# =============================================================================
#  .gitignore
#  PURPOSE: Prevent credential leaks, repository bloat, and accidental commits
#           of generated artifacts. See README.md for what SHOULD be tracked.
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets & environment files
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets/
credentials.json

# -----------------------------------------------------------------------------
# PostgreSQL raw data directories (NEVER commit these)
# -----------------------------------------------------------------------------
data/
pg_data/
pgdata/
postgres-data/
*.pid

# -----------------------------------------------------------------------------
# Database backups & dumps (can be very large)
# -----------------------------------------------------------------------------
*.dump
*.backup
*.bak
*.sql.gz
*.tar.gz
backups/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
pg_log/

# -----------------------------------------------------------------------------
# Editor / IDE
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS noise
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Node / Python tooling (if added later)
# -----------------------------------------------------------------------------
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# -----------------------------------------------------------------------------
# Docker volumes mounted into the workspace
# -----------------------------------------------------------------------------
.docker/
volumes/
